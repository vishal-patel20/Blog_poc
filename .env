# ============================================================
#  Blog REST API — Environment Configuration
#  !! NEVER commit this file to version control !!
# ============================================================

# ----- Application -----------------------------------------------
# Set to 'true' ONLY on local dev; always 'false' in production.
# When false, internal errors are logged server-side and a generic
# "Internal Server Error." is returned to clients.
APP_DEBUG=false

# ----- Authentication (JWT) -----------------------------------------
# Secret key for signing JWT tokens. Must be at least 32 random chars.
# Generate: php -r "echo bin2hex(random_bytes(32));"


# Token TTL = 3600 seconds (1 hour) — configured in Auth::TTL constant.

# ----- CORS ------------------------------------------------------
# The exact origin of your frontend application.
# Only this origin will receive Access-Control-Allow-Origin.
# Leave empty to deny ALL cross-origin requests (safest for API-only).
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ----- Rate Limiting (informational — values set in RateLimiter.php) --
# Current limits: 60 requests / 60-second window per IP.
# Adjust RateLimiter::LIMIT and RateLimiter::WINDOW constants to change.

# ----- Reverse Proxy / Load Balancer ------------------------------------
# Comma-separated IPs of trusted reverse proxies (e.g. your load balancer).
# When set, X-Forwarded-For is trusted ONLY from these IPs.
# Leave empty for direct-access servers (no load balancer in front).
TRUSTED_PROXIES=
