{
    "name": "trainee/blog-rest-api",
    "description": "A Blog REST API built with pure PHP 8 — no framework.",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests/",
        "lint": "phpcs --standard=PSR12 src/"
    },
    "config": {
        "optimize-autoloader": true
    }
}
