{
    "info": {
        "_postman_id": "blog-rest-api-collection",
        "name": "Blog REST API",
        "description": "All 8 endpoints for the Blog REST API POC. Start local server: php -S localhost:8000 -t public",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Posts",
            "item": [
                {
                    "name": "GET All Posts (paginated)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/posts?page=1&per_page=10",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "posts"],
                            "query": [
                                {"key": "page", "value": "1"},
                                {"key": "per_page", "value": "10"}
                            ]
                        }
                    }
                },
                {
                    "name": "GET Single Post",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/posts/1",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "posts", "1"]
                        }
                    }
                },
                {
                    "name": "POST Create Post",
                    "request": {
                        "method": "POST",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"My First Blog Post\",\n    \"body\": \"This is the body of the post.\",\n    \"status\": \"draft\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/posts",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "posts"]
                        }
                    }
                },
                {
                    "name": "PUT Full Update Post",
                    "request": {
                        "method": "PUT",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Updated Title\",\n    \"body\": \"Updated body content.\",\n    \"status\": \"published\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/posts/1",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "posts", "1"]
                        }
                    }
                },
                {
                    "name": "PATCH Partial Update Post",
                    "request": {
                        "method": "PATCH",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"status\": \"archived\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/posts/1",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "posts", "1"]
                        }
                    }
                },
                {
                    "name": "DELETE Soft-Delete Post",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/api/posts/1",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "posts", "1"]
                        }
                    }
                }
            ]
        },
        {
            "name": "Comments",
            "item": [
                {
                    "name": "GET Comments for Post",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/posts/1/comments",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "posts", "1", "comments"]
                        }
                    }
                },
                {
                    "name": "POST Add Comment to Post",
                    "request": {
                        "method": "POST",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"author\": \"Jane Doe\",\n    \"body\": \"This is a great post!\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/posts/1/comments",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "posts", "1", "comments"]
                        }
                    }
                }
            ]
        }
    ]
}
