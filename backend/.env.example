# ============================================================
#  Blog REST API — Environment Configuration Template
#  Copy this file to .env and fill in real values.
#  Run: copy .env.example .env   (Windows)
#       cp .env.example .env     (Linux/macOS)
# ============================================================

# ----- Application -----------------------------------------------
# 'true' for local dev, 'false' in production
APP_DEBUG=false

# ----- JWT Authentication ----------------------------------------
# REQUIRED — the app will refuse to start without this.
# Generate a strong key: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_KEY

# ----- API Key ---------------------------------------------------
# Optional additional API key if needed.
API_KEY=REPLACE_WITH_A_STRONG_RANDOM_KEY

# ----- CORS ------------------------------------------------------
# Your frontend origin, e.g. https://yourapp.com
# Leave empty to deny all cross-origin requests.
CORS_ALLOWED_ORIGIN=

# ----- Trusted Proxies -------------------------------------------
# Comma-separated list of trusted proxy IPs (e.g. load balancer).
# Leave empty if not behind a proxy.
TRUSTED_PROXIES=
